# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real keys.

# Anthropic API key — required.
# Your friend will provide this for you (it's his account, paying for your usage).
# Treat this like a password: don't share it, don't paste it into chats, don't commit it.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Neon DB connection string — required.
# Create a free Neon account at https://console.neon.tech/
# Create a new project, then copy the connection string from the dashboard.
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://username:password@ep-example-123456.us-east-1.aws.neon.tech/neondb?sslmode=require

# AssemblyAI API key — OPTIONAL.
# Only needed if you want to use the "Process Transcript" feature to diarize
# audio recordings of group therapy sessions. Skip this if you don't need it.
# Get a free key with $50 credit at https://www.assemblyai.com
ASSEMBLYAI_API_KEY=
